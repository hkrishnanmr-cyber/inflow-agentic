# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg

# ---------------------------------------------------------------------------
# Virtual environments
# ---------------------------------------------------------------------------
.venv/
venv/
env/
ENV/

# ---------------------------------------------------------------------------
# Environment variables / secrets
# ---------------------------------------------------------------------------
.env
.env.*
*.env

# API keys / credentials (common in agentic / LLM projects)
secrets.json
credentials.json
*.key
*.pem

# ---------------------------------------------------------------------------
# pytest / testing
# ---------------------------------------------------------------------------
.pytest_cache/
.cache/

# Coverage
.coverage
.coverage.*
htmlcov/
coverage.xml
.tox/
.nox/

# ---------------------------------------------------------------------------
# Generated artifacts
# Ignore the CONTENTS of these folders but keep the folders themselves.
# (Add a .gitkeep file inside each one so Git tracks the empty folder.)
# ---------------------------------------------------------------------------
outputs/*
!outputs/.gitkeep

results/*
!results/.gitkeep

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
*.log
logs/

# ---------------------------------------------------------------------------
# IDE / editor
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# Keep .clinerules tracked (project config for Cline) -- do NOT ignore it.

# ---------------------------------------------------------------------------
# OS
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ---------------------------------------------------------------------------
# Misc tooling caches
# ---------------------------------------------------------------------------
.mypy_cache/
.ruff_cache/
.dmypy.json
*.tmp
*.bak